# ============================================================
# HotelBookCI — Variables d'environnement (exemple)
# Copiez ce fichier en .env et remplissez les valeurs
# NE JAMAIS committer le fichier .env sur GitHub !
# ============================================================

SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données (SQLite par défaut, laisser vide)
DATABASE_URL=

# CORS — URLs autorisées pour le frontend
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# JWT — Durée des tokens (en minutes)
ACCESS_TOKEN_LIFETIME=60
REFRESH_TOKEN_LIFETIME=1440
